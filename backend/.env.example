# Copy this file to .env and fill in your values
# DO NOT commit .env to git

PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"
MONGODB_URI="mongodb://127.0.0.1:27017"
# Example Atlas URI:
# MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=AI-VAOM"
MONGODB_DB_NAME="ai_vaom"
MONGODB_ORDERS_COLLECTION="orders"
REQUEST_BODY_LIMIT="20kb"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_USER_EMAIL="admin@ai-vaom.local"
AUTH_USER_PASSWORD="ChangeMe123!"
AUTH_USER_DISPLAY_NAME="Operations Admin"
AUTH_USER_PHOTO_URL="https://ui-avatars.com/api/?name=Operations+Admin"
AUTH_SESSION_TTL_MS=86400000
NODE_ENV=development
