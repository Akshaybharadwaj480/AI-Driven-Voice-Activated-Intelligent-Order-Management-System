# Copy this file to .env and fill in your values
# DO NOT commit .env to git

PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"
MONGODB_URI="mongodb://127.0.0.1:27017"
# Example Atlas URI:
# MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority&appName=AI-VAOM"
MONGODB_DB_NAME="ai_vaom"
MONGODB_ORDERS_COLLECTION="orders"
PYTHON_EXECUTABLE=""
ENABLE_PYTHON_BROWSER_OPEN=true
VOICE_ASSISTANT_BACKEND_URL="http://localhost:4000/api/voice-command"
VOICE_ASSISTANT_LISTEN_TIMEOUT=6
VOICE_ASSISTANT_PHRASE_TIME_LIMIT=8
VOICE_ASSISTANT_HTTP_TIMEOUT=15
VOICE_ASSISTANT_LANGUAGE="en-US"
VOICE_ASSISTANT_TTS_RATE=180
VOICE_ASSISTANT_TTS_VOLUME=1.0
VOICE_ASSISTANT_ENABLE_SELENIUM_AUTOMATION=true
VOICE_ASSISTANT_SELENIUM_HEADLESS=false
VOICE_ASSISTANT_AUTOMATION_TIMEOUT=20
REQUEST_BODY_LIMIT="20kb"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
AUTH_USER_EMAIL="admin@ai-vaom.local"
AUTH_USER_PASSWORD="ChangeMe123!"
AUTH_USER_DISPLAY_NAME="Operations Admin"
AUTH_USER_PHOTO_URL="https://ui-avatars.com/api/?name=Operations+Admin"
AUTH_SESSION_TTL_MS=86400000
NODE_ENV=development
